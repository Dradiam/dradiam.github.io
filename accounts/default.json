{
  "main": {
    "deviceDescription": "RobCo Termlink (TM)",
    "deviceAlias": "RIT-V300",
    "userAccountName": "default",
    "userName": "$USER"
  },
  "widgetSettings": {
    "widgetList": [
      { "type": "userDetails", "id": "nameDisplay" },
      { "type": "userDetails", "id": "roleDisplay" },
      { "type": "clockWidget", "id": "dateDisplay" },
      { "type": "clockWidget", "id": "clockDisplay" }
    ],
    "userDetails": {
      "nameDisplay": { 
        "source": "userName" 
      },
      "roleDisplay": { 
        "source": "deviceAlias" 
      }
    },
    "clockWidget": {
      "dateDisplay": {
        "dayFormat" : "long",
        "dateFormat": "iso",
        "dateSeparator": "/",
        "timeFormat": "HH:mm",
	"customYearStart" : 2296,
        "widgetFormat" : ["dateFormat"]
      },
      "clockDisplay": {
        "dayFormat" : "long",
        "dateFormat": "long",
        "dateSeparator": ".",
        "timeFormat": "HH:mm",
        "widgetFormat" : ["clockFormat"]
      }
    }
  },
  "themeSettings": {
    "theme": "classique",
    "font": "classique",
    "colorScheme": "green",
    "customRGB": ""
  },
  "fs": {
    "menuID": "menuMain",
    "menuItemLabel": "Main Menu",
    "menuItemType": "menu",
    "menuItemContent": [
      {
        "menuItemID": "defaultAbout",
        "menuItemLabel": "About",
        "menuItemType": "txt",
        "menuItemContent": "content/default/default.txt"
      },
      {
        "menuItemID": "defaultFileStorage",
        "menuItemLabel": "File Storage",
        "menuItemType": "menu",
        "menuItemContent": [
          {
            "menuItemID": "defaultFS001",
            "menuItemLabel": "ozy.txt",
            "menuItemType": "txt",
            "menuItemContent": "content/default/ozy.txt"
          },
          {
            "menuItemID": "defaultFS002",
            "menuItemLabel": "smrknd.txt",
            "menuItemType": "txt",
            "menuItemContent": "content/default/smrknd.txt"
          }
        ]
      }
    ]
  }
}
