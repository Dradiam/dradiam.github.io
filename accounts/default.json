{
  "main": {
    "deviceDescription": "RobCo Termlink (TM)",
    "deviceAlias": "RIT-V300",
    "userAccountName": "default",
    "userName": "$USER"
  },
  "widgetSettings": {
    "widgetList": [
      { "type": "userDetails", "id": "nameDisplay" },
      { "type": "userDetails", "id": "roleDisplay" },
      { "type": "clockWidget", "id": "dateDisplay" },
      { "type": "clockWidget", "id": "clockDisplay" }
    ],
    "userDetails": {
      "nameDisplay": { 
        "source": "userName"
      },
      "roleDisplay": { 
        "source": "deviceAlias" 
      }
    },
    "clockWidget": {
      "dateDisplay": {
        "dayFormat" : "long",
        "dateFormat": "iso",
        "widgetFormat" : ["dayFormat", "dateFormat"]
      },
      "clockDisplay": {
        "timeFormat": "hh:mm",
        "widgetFormat" : ["clockFormat"]
      }
    }
  },
  "themeSettings": {
    "themeType": "classique",
    "fontType": "classique",
    "colorValue": "green",
    "customValue": ""
  },
  "fs": {
    "menuID": "menuMain",
    "menuItemLabel": "Main Menu",
    "menuItemType": "menu",
    "menuItemContent": [
      {
        "menuItemID": "defaultAbout",
        "menuItemLabel": "About",
        "menuItemType": "txt",
        "menuItemContent": "content/default/default.txt"
      },
      {
        "menuItemID": "defaultReleaseNotes",
        "menuItemLabel": "Release Notes",
        "menuItemType": "html",
        "menuItemContent": "content/default/releasenotes.json"
      },
      {
        "menuItemID": "defaultFileStorage",
        "menuItemLabel": "File Storage",
        "menuItemType": "menu",
        "menuItemContent": [
          {
            "menuItemID": "defaultFS001",
            "menuItemLabel": "ozy.txt",
            "menuItemType": "txt",
            "menuItemContent": "content/default/ozy.txt"
          },
          {
            "menuItemID": "defaultFS001",
            "menuItemLabel": "smrknd.txt",
            "menuItemType": "txt",
            "menuItemContent": "content/default/smrknd.txt"
          }
        ]
      }
    ]
  }
}
